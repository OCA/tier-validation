<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="tier_review_view_form_board" model="ir.ui.view">
        <field name="name">tier.review.boards.view.form</field>
        <field name="model">tier.review</field>
        <field name="arch" type="xml">
            <form create="false" edit="false" delete="false">
                <sheet>
                    <button
                        name="open_origin"
                        type="object"
                        class="centre oe_link"
                        nolabel="1"
                    >
                        <field name="res_name" invisible="1" />
                        <h1>
                            <field name="related_model_instance" />
                        </h1>
                    </button>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="sequence" />
                            <field name="requested_by" widget="many2one_avatar_user" />
                            <field name="todo_by" />
                        </group>
                        <group>
                            <field name="status" widget="badge" />
                            <field name="done_by" widget="many2one_avatar_user" />
                            <field name="reviewed_date" />
                            <field name="comment" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="tier_review_view_kanban" model="ir.ui.view">
        <field name="name">tier.review.boards.view.kanban</field>
        <field name="model">tier.review</field>
        <field name="arch" type="xml">
            <kanban
                default_group_by="status"
                class="o_kanban_small_column"
                create="0"
                quick_create="0"
                edit="0"
                group_create="false"
                group_delete="false"
                group_edit="false"
            >
                <field name="status" />
                <field name="requested_by" />
                <field name="reviewer_ids" />
                <field name="todo_by" />
                <field name="done_by" />
                <field name="comment" />
                <field name="create_date" />
                <field name="reviewed_date" />
                <field name="is_overdue" />
                <field name="activity_ids" />
                <templates>
                    <t
                        t-name="card"
                        t-att-class="record.is_overdue.raw_value and 'border-danger bg-danger-subtle' or ''"
                    >
                        <div class="o_kanban_record_top">
                            <div class="o_kanban_record_headings">
                                <strong class="o_kanban_record_title d-block">
                                    <field name="res_name" />
                                </strong>
                                <small
                                    class="o_kanban_record_subtitle text-muted d-block"
                                >
                                    <field name="name" />
                                </small>
                            </div>
                        </div>
                        <div class="o_kanban_record_body">
                            <div class="d-flex align-items-center mb-1">
                                <span class="text-muted me-2">Requested by</span>
                                <field
                                    name="requested_by"
                                    widget="many2one_avatar_user"
                                />
                                <span class="ms-2" t-out="record.requested_by.value" />
                            </div>
                            <div
                                t-if="record.reviewer_ids.raw_value.length"
                                class="d-flex align-items-center mb-1"
                            >
                                <span class="text-muted me-2">To review</span>
                                <field
                                    name="reviewer_ids"
                                    widget="many2many_avatar_user"
                                />
                            </div>
                            <div
                                t-if="!record.reviewer_ids.raw_value.length and record.todo_by.raw_value"
                                class="mb-1"
                            >
                                <span class="text-muted">Todo by: </span>
                                <field name="todo_by" />
                            </div>
                            <div
                                t-if="record.done_by.raw_value"
                                class="d-flex align-items-center mb-1"
                            >
                                <span class="text-muted me-2">Done by</span>
                                <field name="done_by" widget="many2one_avatar_user" />
                                <span class="ms-2" t-out="record.done_by.value" />
                                <span class="ms-2 text-muted">on </span>
                                <field
                                    name="reviewed_date"
                                    widget="date"
                                    class="ms-1"
                                />
                            </div>
                            <div t-if="record.comment.raw_value" class="mb-1">
                                <span class="text-muted">Comment: </span>
                                <field name="comment" />
                            </div>
                        </div>
                        <div class="o_kanban_record_bottom">
                            <div class="oe_kanban_bottom_left text-muted small">
                                Requested <field name="create_date" widget="date" />
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <field name="activity_ids" widget="kanban_activity" />
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="tier_review_view_pivot" model="ir.ui.view">
        <field name="name">tier.review.boards.view.pivot</field>
        <field name="model">tier.review</field>
        <field name="arch" type="xml">
            <pivot string="Tier Reviews" sample="1">
                <field name="model_id" type="row" />
                <field name="status" type="col" />
                <field name="response_days" type="measure" />
            </pivot>
        </field>
    </record>

    <record id="tier_review_view_graph" model="ir.ui.view">
        <field name="name">tier.review.boards.view.graph</field>
        <field name="model">tier.review</field>
        <field name="arch" type="xml">
            <graph string="Tier Reviews" type="bar" sample="1">
                <field name="status" type="row" />
                <field name="response_days" type="measure" />
            </graph>
        </field>
    </record>

    <record id="tier_review_view_search" model="ir.ui.view">
        <field name="name">tier.review.boards.view.search</field>
        <field name="model">tier.review</field>
        <field name="arch" type="xml">
            <search>
                <field
                    name="name"
                    string="Review"
                    filter_domain="['|', ('name', 'ilike', self), ('res_name', 'ilike', self)]"
                />
                <field name="requested_by" />
                <field name="done_by" />
                <field name="model_id" />
                <filter
                    name="my_reviews"
                    string="To review by me"
                    domain="[('reviewer_ids', 'in', uid), ('status', 'in', ['pending', 'waiting'])]"
                />
                <filter
                    name="requested_by_me"
                    string="Requested by me"
                    domain="[('requested_by', '=', uid)]"
                />
                <filter
                    name="done_by_me"
                    string="Reviewed by me"
                    domain="[('done_by', '=', uid)]"
                />
                <separator />
                <filter
                    name="state_pending"
                    string="Pending"
                    domain="[('status', '=', 'pending')]"
                />
                <filter
                    name="state_waiting"
                    string="Waiting"
                    domain="[('status', '=', 'waiting')]"
                />
                <filter
                    name="state_approved"
                    string="Approved"
                    domain="[('status', '=', 'approved')]"
                />
                <filter
                    name="state_rejected"
                    string="Rejected"
                    domain="[('status', '=', 'rejected')]"
                />
                <separator />
                <filter
                    name="overdue"
                    string="Overdue"
                    domain="[('is_overdue', '=', True)]"
                    help="Pending or waiting reviews older than the configured overdue threshold."
                />
                <filter
                    name="reviewed_today"
                    string="Reviewed today"
                    domain="[('reviewed_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"
                />
                <filter
                    name="requested_last_week"
                    string="Requested in last 7 days"
                    domain="[('create_date', '&gt;=', (context_today() - relativedelta(days=7)).strftime('%Y-%m-%d'))]"
                />
                <group>
                    <filter
                        name="group_status"
                        string="Status"
                        context="{'group_by': 'status'}"
                    />
                    <filter
                        name="group_model"
                        string="Model"
                        context="{'group_by': 'model_id'}"
                    />
                    <filter
                        name="group_requested_by"
                        string="Requested by"
                        context="{'group_by': 'requested_by'}"
                    />
                    <filter
                        name="group_done_by"
                        string="Reviewed by"
                        context="{'group_by': 'done_by'}"
                    />
                    <filter
                        name="group_definition"
                        string="Definition"
                        context="{'group_by': 'definition_id'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="open_boards_tier_reviews">
        <field name="name">Tier Reviews</field>
        <field name="res_model">tier.review</field>
        <field name="view_mode">kanban,list,form,pivot,graph</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                          (0, 0, {'view_mode': 'kanban', 'view_id': ref('tier_review_view_kanban')}),
                          (0, 0, {'view_mode': 'list', 'view_id': ref('base_tier_validation.tier_review_view_tree')}),
                          (0, 0, {'view_mode': 'form', 'view_id': ref('tier_review_view_form_board')}),
                          (0, 0, {'view_mode': 'pivot', 'view_id': ref('tier_review_view_pivot')}),
                          (0, 0, {'view_mode': 'graph', 'view_id': ref('tier_review_view_graph')})]"
        />
        <field name="search_view_id" ref="tier_review_view_search" />
    </record>

    <record id="tier_review_view_stats_pivot" model="ir.ui.view">
        <field name="name">tier.review.boards.view.stats.pivot</field>
        <field name="model">tier.review</field>
        <field name="arch" type="xml">
            <pivot string="Review Statistics" sample="1">
                <field name="done_by" type="row" />
                <field name="status" type="col" />
                <field name="response_days" type="measure" />
            </pivot>
        </field>
    </record>

    <record id="tier_review_view_stats_graph" model="ir.ui.view">
        <field name="name">tier.review.boards.view.stats.graph</field>
        <field name="model">tier.review</field>
        <field name="arch" type="xml">
            <graph string="Review Statistics" type="bar" sample="1">
                <field name="done_by" type="row" />
                <field name="response_days" type="measure" />
            </graph>
        </field>
    </record>

    <record model="ir.actions.act_window" id="open_review_statistics">
        <field name="name">Review Statistics</field>
        <field name="res_model">tier.review</field>
        <field name="view_mode">pivot,graph</field>
        <field
            name="domain"
        >[("done_by", "!=", False), ("status", "in", ("approved", "rejected"))]</field>
        <field name="context">{}</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                          (0, 0, {'view_mode': 'pivot', 'view_id': ref('tier_review_view_stats_pivot')}),
                          (0, 0, {'view_mode': 'graph', 'view_id': ref('tier_review_view_stats_graph')})]"
        />
        <field name="search_view_id" ref="tier_review_view_search" />
        <field name="help">&lt;p class="o_view_nocontent_smiling_face"&gt;
            No completed reviews to chart yet.
            &lt;/p&gt;&lt;p&gt;
            Statistics are computed across approved and rejected reviews.
            The default *Avg. days* measure shows the average response
            time per reviewer. Use the *Group by* menu in the search bar
            to slice by Model, Definition or Requested by.
            &lt;/p&gt;</field>
    </record>

    <record model="ir.actions.act_window" id="open_my_tier_reviews">
        <field name="name">My Tier Reviews</field>
        <field name="res_model">tier.review</field>
        <field name="view_mode">list,kanban,form,pivot,graph</field>
        <field
            name="domain"
        >[("reviewer_ids", "in", uid), ("status", "in", ("pending", "waiting"))]</field>
        <field name="context">{"search_default_my_reviews": 1}</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                          (0, 0, {'view_mode': 'list', 'view_id': ref('base_tier_validation.tier_review_view_tree')}),
                          (0, 0, {'view_mode': 'kanban', 'view_id': ref('tier_review_view_kanban')}),
                          (0, 0, {'view_mode': 'form', 'view_id': ref('tier_review_view_form_board')}),
                          (0, 0, {'view_mode': 'pivot'}),
                          (0, 0, {'view_mode': 'graph'})]"
        />
        <field name="search_view_id" ref="tier_review_view_search" />
    </record>

    <menuitem
        id="menu_tier_reviews_root"
        name="Tier Reviews"
        parent="spreadsheet_dashboard.spreadsheet_dashboard_menu_root"
        sequence="1"
    />
    <menuitem
        id="menu_my_tier_reviews"
        name="My Reviews"
        parent="menu_tier_reviews_root"
        action="open_my_tier_reviews"
        sequence="10"
    />
    <menuitem
        id="board_menu_tier_reviews"
        name="All Reviews"
        parent="menu_tier_reviews_root"
        action="open_boards_tier_reviews"
        groups="group_show_tier_review_board"
        sequence="20"
    />
    <menuitem
        id="menu_tier_review_statistics"
        name="Review Statistics"
        parent="menu_tier_reviews_root"
        action="open_review_statistics"
        groups="group_show_tier_review_board"
        sequence="30"
    />
</odoo>
